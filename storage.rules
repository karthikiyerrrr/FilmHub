rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /videos/{videoId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /analysis/{videoId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /output/{videoId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
