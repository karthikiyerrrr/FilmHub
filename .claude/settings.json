{
  "permissions": {
    "allow": [
      "Bash(.venv/bin/python -m filmhub.cut_video*)",
      "Bash(.venv/bin/python -m filmhub.transcribe*)",
      "Bash(.venv/bin/python -m filmhub.detect_music*)",
      "Bash(.venv/bin/python -m filmhub.detect_graphics*)",
      "Read(analysis/*)",
      "Read(analysis/*_graphics_frames/*)",
      "Write(analysis/*)",
      "Write(output/*)",
      "Write(output/*_clean_cuts.json)",
      "Bash(reviewer/target/release/reviewer*)",
      "Bash(cd reviewer && cargo build*)",
      "Bash(cd reviewer/frontend && npm*)"
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  }
}
